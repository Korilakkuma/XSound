{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "outDir": "./build/",
    "rootDir": "./",
    "paths": {
      "/src/*": ["./src/*"],
      "/mock/*": ["./mock/*"]
    },
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "types": [
      "node",
      "jest",
      "audioworklet"
    ]
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "mock/**/*"
  ]
}
